{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AURA AI IDE",
  "version": "0.1.0",
  "identifier": "com.aura.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AURA AI IDE",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxODREMTdCQjE1NkM3MkIKUldRcngxYXhlOUdFNFU5VnA5Mm9MdWlXK2h2NFZtTzBMMkw2UVRueGtNbmZwRjZLUGkwZ3NpcWsK",
      "endpoints": [
        "https://github.com/budagbogor/auraide/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
